{
  "include": ["./src"],
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist",
    "module": "preserve",
    "moduleResolution": "bundler",
    "target": "es2020",
    "types": [],
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "strict": true,
    "jsx": "react-jsx",
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
    // tsupのDTSビルドがbaseUrl:"."を自動注入するため（tsup側の制限）
    "ignoreDeprecations": "6.0",
    "paths": {
      "@/*": ["./src/*"]
    }
  }
}